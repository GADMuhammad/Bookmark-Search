{
  "name": "bookmark-search",
  "displayName": "Bookmark search",
  "version": "0.0.1",
  "description": "A minimal and lightning-fast bookmark search extension with a beautiful frosted-glass UI.",
  "author": "Muhammad Gad",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "sass": "^1.101.0",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "bookmarks",
      "favicon"
    ],
    "host_permissions": [
      "https://*/*"
    ],
    "commands": {
      "open-popup": {
        "suggested_key": {
          "default": "Ctrl+E",
          "mac": "MacCtrl+E"
        },
        "description": "Open Bookmark Search Popup"
      }
    }
  }
}
